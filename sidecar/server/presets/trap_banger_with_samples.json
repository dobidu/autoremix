{
  "id": "trap_banger_with_samples",
  "version": "2.0",
  "name": "Trap Banger (With Samples)",
  "description": "Structure-aware trap remix with auto-placed samples from user library. Drop a riser and impact WAV in ~/autoremix/samples/ to hear them placed automatically.",
  "author": "AutoRemix",
  "tags": ["trap", "hip-hop", "structured", "samples"],
  "engine": "structured_remix",
  "params": {
    "tempo_factor": 0.95,
    "pitch_shift_semi": -1.0,
    "reverb_mix": 0.08,
    "chop_interval_ms": 0.0,
    "bass_boost_db": 0.0,
    "drums_tempo_factor": 1.0
  },
  "stem_mix": { "vocals": 1.0, "drums": 1.0, "bass": 1.0, "other": 1.0 },
  "effects": [],
  "structure": {
    "enabled": true,
    "arrangement": [
      { "section": "intro", "length_bars": 4, "anchor": "first",
        "layer": { "vocals": 0.3, "drums": 0.8, "bass": 0.8, "other": 0.5 } },
      { "section": "verse", "length_bars": 8, "anchor": "second",
        "layer": { "vocals": 1.0, "drums": 1.0, "bass": 1.0, "other": 0.8 } },
      { "section": "drop",  "length_bars": 8, "anchor": "energy_peak",
        "layer": { "vocals": 0.5, "drums": 1.5, "bass": 1.5, "other": 0.7 } },
      { "section": "outro", "length_bars": 4, "anchor": "last",
        "layer": { "vocals": 0.5, "drums": 0.6, "bass": 0.6, "other": 0.4 } }
    ],
    "samples": [
      { "category": "riser",  "placement": "pre_drop", "gain": 0.8, "fade_ms": 200 },
      { "category": "impact", "placement": "drop",     "gain": 1.0, "fade_ms": 10  }
    ],
    "scratch":  { "enabled": false },
    "build_up": { "enabled": false }
  }
}
